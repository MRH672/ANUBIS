{
  "name": "anubis-cinematic",
  "version": "1.0.0",
  "description": "ANUBIS cinematic Electron interface",
  "main": "main.js",
  "scripts": {
    "start": "npm run build:renderer && electron .",
    "debug": "ANUBIS_DEBUG=1 npm run build:renderer && ANUBIS_DEBUG=1 electron .",
    "dev": "vite --host 127.0.0.1 --config renderer/vite.config.mjs",
    "build:renderer": "vite build --config renderer/vite.config.mjs",
    "build": "npm run build:renderer && electron-builder",
    "buildwin": "npm run build:renderer && electron-builder --win",
    "buildmac": "npm run build:renderer && electron-builder --mac",
    "buildlinux": "npm run build:renderer && electron-builder --linux"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.19"
  },
  "build": {
    "appId": "com.anubis.cinematic",
    "productName": "ANUBIS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "scripts/**/*",
      "renderer/**/*",
      "!renderer/src/**/*",
      "!renderer/vite.config.*",
      "!renderer/tailwind.config.js",
      "!renderer/postcss.config.js",
      "assets/**/*",
      "data/**/*",
      "Reports/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icons/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icons/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icons/icon.png"
    }
  }
}
